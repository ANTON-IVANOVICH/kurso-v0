# Copy to .env for local overrides. All values have sane defaults in code.

# dev | production
KURSO_ENV=dev

# HTTP
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# Postgres
DATABASE_URL=postgres://kurso:kurso@localhost:5432/kurso?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging: level debug|info|warn|error, format json|text
LOG_LEVEL=info
LOG_FORMAT=text
